server <- function(input, output, session) {
        authenticated <- reactiveVal(FALSE)
        logged_in_user <- reactiveVal(NULL)
        
        output$page_ui <- renderUI({
                if (isTRUE(authenticated())) {
                        main_app_ui
                } else {
                        login_ui
                }
        })
        
        output$login_status <- renderUI(NULL)
        
        observeEvent(input$login_btn, {
                user <- trimws(input$login_user)
                pass <- input$login_pass
                
                if (check_login(user, pass)) {
                        authenticated(TRUE)
                        logged_in_user(user)
                        output$login_status <- renderUI(NULL)
                } else {
                        output$login_status <- renderUI({
                                div(class = "status-box status-err", "Invalid username or password.")
                        })
                }
        })
        
        observeEvent(input$logout_btn, {
                authenticated(FALSE)
                logged_in_user(NULL)
        })
        
        date_str <- reactiveVal(today_ymd())
        
        output$today_out <- renderText({
                paste0("Today: ", date_str())
        })
        
        saved_s1 <- reactiveVal(NULL)
        saved_s2 <- reactiveVal(NULL)
        refresh_ms <- reactiveVal(300000)
        
        set_status <- function(output_id, text, cls = "status-wip") {
                output[[output_id]] <- renderUI({
                        div(class = paste("status-box", cls), text)
                })
        }
        
        set_buttons_enabled <- function(enabled = TRUE) {
                ids <- c("submit_services", "submit_adults", "submit_children", "refresh")
                for (id in ids) {
                        if (enabled) {
                                shinyjs::enable(id)
                        } else {
                                shinyjs::disable(id)
                        }
                }
        }
        
        boost_refresh_temporarily <- function() {
                refresh_ms(60000)
                later::later(function() {
                        refresh_ms(300000)
                }, delay = 300)
        }
        
        pull_saved <- function() {
                d <- isolate(date_str())
                saved_s1(get_saved_row(SHEET1_ID, SHEET1_TAB, S1_COLS, d))
                saved_s2(get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d))
        }
        
        observeEvent(authenticated(), {
                if (isTRUE(authenticated())) {
                        pull_saved()
                }
        }, ignoreInit = FALSE)
        
        observe({
                req(authenticated())
                invalidateLater(refresh_ms(), session)
                try({
                        pull_saved()
                }, silent = TRUE)
        })
        
        observe({
                req(authenticated())
                invalidateLater(10000, session)
                try({
                        pull_saved()
                }, silent = TRUE)
        })
        
        observe({
                req(authenticated())
                
                s1 <- saved_s1()
                s2 <- saved_s2()
                
                get_service_saved <- function(which_input) {
                        if (which_input == "ascent") {
                                if (!is.null(s1) && "First/Ascent" %in% names(s1) && !is.na(s1[["First/Ascent"]][1])) {
                                        return(s1[["First/Ascent"]][1])
                                }
                        }
                        if (which_input == "sanctuary") {
                                if (!is.null(s1) && "Second/Sanctuary" %in% names(s1) && !is.na(s1[["Second/Sanctuary"]][1])) {
                                        return(s1[["Second/Sanctuary"]][1])
                                }
                        }
                        if (which_input == "ascent_online") {
                                if (!is.null(s1) && "AscentOnline" %in% names(s1) && !is.na(s1[["AscentOnline"]][1])) {
                                        return(s1[["AscentOnline"]][1])
                                }
                        }
                        if (which_input == "sanctuary_online") {
                                if (!is.null(s1) && "SanctuaryOnline" %in% names(s1) && !is.na(s1[["SanctuaryOnline"]][1])) {
                                        return(s1[["SanctuaryOnline"]][1])
                                }
                        }
                        ""
                }
                
                output$ascent_saved <- renderText(get_service_saved("ascent"))
                output$sanctuary_saved <- renderText(get_service_saved("sanctuary"))
                output$ascent_online_saved <- renderText(get_service_saved("ascent_online"))
                output$sanctuary_online_saved <- renderText(get_service_saved("sanctuary_online"))
                
                for (i in seq_along(ADULT_CLASS_COLS)) {
                        local({
                                ii <- i
                                nm <- ADULT_CLASS_COLS[ii]
                                out_id <- paste0("adult_", ii, "_saved")
                                
                                output[[out_id]] <- renderText({
                                        s2 <- saved_s2()
                                        if (is.null(s2) || !(nm %in% names(s2))) return("")
                                        v <- s2[[nm]][1]
                                        if (is.na(v)) "" else as.character(v)
                                })
                        })
                }
                
                for (i in seq_along(CHILD_CLASS_COLS)) {
                        local({
                                ii <- i
                                nm <- CHILD_CLASS_COLS[ii]
                                out_id <- paste0("child_", ii, "_saved")
                                
                                output[[out_id]] <- renderText({
                                        s2 <- saved_s2()
                                        if (is.null(s2) || !(nm %in% names(s2))) return("")
                                        v <- s2[[nm]][1]
                                        if (is.na(v)) "" else as.character(v)
                                })
                        })
                }
        })
        
        observeEvent(input$refresh, {
                req(authenticated())
                set_buttons_enabled(FALSE)
                set_status("refresh_status", "Refreshing...", "status-wip")
                
                tryCatch({
                        pull_saved()
                        set_status("refresh_status", "✓ Saved", "status-ok")
                        set_buttons_enabled(TRUE)
                }, error = function(e) {
                        set_status("refresh_status", paste("Refresh failed:", e$message), "status-err")
                        set_buttons_enabled(TRUE)
                })
        })
        
        observeEvent(input$submit_services, {
                req(authenticated())
                set_buttons_enabled(FALSE)
                set_status("services_status", "Saving...", "status-wip")
                
                d <- date_str()
                
                vals_sheet1 <- list(
                        "First/Ascent" = as_int_or_na(input$ascent),
                        "Second/Sanctuary" = as_int_or_na(input$sanctuary),
                        "AscentOnline" = as_int_or_na(input$ascent_online),
                        "SanctuaryOnline" = as_int_or_na(input$sanctuary_online),
                        "Church_status" = "Open"
                )
                
                vals_sheet2 <- list(
                        "Ascent" = as_int_or_na(input$ascent),
                        "Sanctuary" = as_int_or_na(input$sanctuary),
                        "Ascent Online" = as_int_or_na(input$ascent_online),
                        "Sanctuary Online" = as_int_or_na(input$sanctuary_online)
                )
                
                tryCatch({
                        with_sheet_lock(SHEET1_ID, SHEET1_TAB, SHEET1_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET1_ID, SHEET1_TAB, S1_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged <- modifyList(merged, vals_sheet1)
                                merged[["Date"]] <- d
                                merged <- compute_sheet1_totals(merged)
                                upsert_by_date(SHEET1_ID, SHEET1_TAB, S1_COLS, d, merged)
                        })
                        
                        with_sheet_lock(SHEET2_ID, SHEET2_TAB, SHEET2_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged <- modifyList(merged, vals_sheet2)
                                merged[["Date"]] <- d
                                merged <- compute_sheet2_totals(merged)
                                upsert_by_date(SHEET2_ID, SHEET2_TAB, S2_COLS, d, merged)
                        })
                        
                        pull_saved()
                        
                        ok1 <- verify_sheet1_save(d, vals_sheet1)
                        ok2 <- verify_sheet2_services_save(d, vals_sheet2)
                        
                        if (ok1 && ok2) {
                                boost_refresh_temporarily()
                                set_status("services_status", "✓ Saved", "status-ok")
                        } else {
                                set_status("services_status", "Save may have completed, but verification did not fully confirm the spreadsheet values. Please refresh and check.", "status-err")
                        }
                        
                        set_buttons_enabled(TRUE)
                }, error = function(e) {
                        set_status("services_status", paste("Save failed:", e$message), "status-err")
                        set_buttons_enabled(TRUE)
                })
        })
        
        observeEvent(input$submit_adults, {
                req(authenticated())
                set_buttons_enabled(FALSE)
                set_status("adults_status", "Saving...", "status-wip")
                
                d <- date_str()
                vals_adults <- list()
                
                for (i in seq_along(ADULT_CLASS_COLS)) {
                        vals_adults[[ADULT_CLASS_COLS[i]]] <- as_int_or_na(input[[paste0("adult_", i)]])
                }
                
                tryCatch({
                        with_sheet_lock(SHEET2_ID, SHEET2_TAB, SHEET2_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged <- modifyList(merged, vals_adults)
                                merged[["Date"]] <- d
                                merged <- compute_sheet2_totals(merged)
                                upsert_by_date(SHEET2_ID, SHEET2_TAB, S2_COLS, d, merged)
                        })
                        
                        pull_saved()
                        
                        ok <- verify_sheet2_group_save(d, vals_adults)
                        
                        if (ok) {
                                boost_refresh_temporarily()
                                set_status("adults_status", "✓ Saved", "status-ok")
                        } else {
                                set_status("adults_status", "Save may have completed, but verification did not fully confirm the spreadsheet values. Please refresh and check.", "status-err")
                        }
                        
                        set_buttons_enabled(TRUE)
                }, error = function(e) {
                        set_status("adults_status", paste("Save failed:", e$message), "status-err")
                        set_buttons_enabled(TRUE)
                })
        })
        
        observeEvent(input$submit_children, {
                req(authenticated())
                set_buttons_enabled(FALSE)
                set_status("children_status", "Saving...", "status-wip")
                
                d <- date_str()
                vals_children <- list()
                
                for (i in seq_along(CHILD_CLASS_COLS)) {
                        vals_children[[CHILD_CLASS_COLS[i]]] <- as_int_or_na(input[[paste0("child_", i)]])
                }
                
                tryCatch({
                        with_sheet_lock(SHEET2_ID, SHEET2_TAB, SHEET2_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged <- modifyList(merged, vals_children)
                                merged[["Date"]] <- d
                                merged <- compute_sheet2_totals(merged)
                                upsert_by_date(SHEET2_ID, SHEET2_TAB, S2_COLS, d, merged)
                        })
                        
                        pull_saved()
                        
                        ok <- verify_sheet2_group_save(d, vals_children)
                        
                        if (ok) {
                                boost_refresh_temporarily()
                                set_status("children_status", "✓ Saved", "status-ok")
                        } else {
                                set_status("children_status", "Save may have completed, but verification did not fully confirm the spreadsheet values. Please refresh and check.", "status-err")
                        }
                        
                        set_buttons_enabled(TRUE)
                }, error = function(e) {
                        set_status("children_status", paste("Save failed:", e$message), "status-err")
                        set_buttons_enabled(TRUE)
                })
        })
}

