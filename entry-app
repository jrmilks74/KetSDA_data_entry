hash_password <- function(x) {
        digest::digest(x, algo = "sha256", serialize = FALSE)
}

USER_HASHES <- c(
        "USERNAME" = hash_password("PASSWORD!")
)

check_login <- function(username, password) {
        if (is.null(username) || is.null(password) || username == "" || password == "") {
                return(FALSE)
        }
        if (!(username %in% names(USER_HASHES))) {
                return(FALSE)
        }
        identical(unname(USER_HASHES[[username]]), hash_password(password))
}

