server <- function(input, output, session) {
        authenticated <- reactiveVal(FALSE)
        
        output$page_ui <- renderUI({
                if (isTRUE(authenticated())) {
                        main_app_ui
                } else {
                        login_ui
                }
        })
        
        output$login_status <- renderUI(NULL)
        
        show_save_start <- function(msg = "Saving...") {
                showNotification(msg, type = "message", duration = NULL, id = "save_note")
        }
        
        show_save_ok <- function(msg = "✓ Saved") {
                removeNotification("save_note")
                showNotification(msg, type = "message", duration = 3, id = "save_ok_note")
        }
        
        show_save_error <- function(msg) {
                removeNotification("save_note")
                showNotification(msg, type = "error", duration = 8, id = "save_err_note")
        }
        
        observeEvent(input$login_btn, {
                user <- trimws(input$login_user)
                pass <- input$login_pass
                
                if (check_login(user, pass)) {
                        authenticated(TRUE)
                        output$login_status <- renderUI(NULL)
                } else {
                        output$login_status <- renderUI({
                                div(class = "status-box status-err", "Invalid username or password.")
                        })
                }
        })
        
        observeEvent(input$logout_btn, {
                authenticated(FALSE)
        })
        
        date_str <- reactiveVal(today_ymd())
        
        output$today_out <- renderText({
                paste0("Today: ", date_str())
        })
        
        saved_s1 <- reactiveVal(NULL)
        saved_s2 <- reactiveVal(NULL)
        
        set_status <- function(output_id, text, cls = "status-wip") {
                output[[output_id]] <- renderUI({
                        div(class = paste("status-box", cls), text)
                })
        }
        
        set_buttons_enabled <- function(enabled = TRUE, ids = NULL) {
                if (is.null(ids)) {
                        ids <- c("refresh")
                        ids <- c(
                                ids,
                                paste0("submit_", names(SERVICE_FIELD_MAP)),
                                paste0("submit_adult_", seq_along(ADULT_CLASS_COLS)),
                                paste0("submit_child_", seq_along(CHILD_CLASS_COLS))
                        )
                }
                
                for (id in ids) {
                        if (enabled) shinyjs::enable(id) else shinyjs::disable(id)
                }
        }
        
        clear_statuses <- function() {
                for (id in c(
                        paste0(names(SERVICE_FIELD_MAP), "_status"),
                        paste0("adult_", seq_along(ADULT_CLASS_COLS), "_status"),
                        paste0("child_", seq_along(CHILD_CLASS_COLS), "_status"),
                        "refresh_status"
                )) {
                        output[[id]] <- renderUI(NULL)
                }
        }
        
        pull_saved <- function() {
                d <- isolate(date_str())
                saved_s1(get_saved_row(SHEET1_ID, SHEET1_TAB, S1_COLS, d))
                saved_s2(get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d))
        }
        
        render_saved_value <- function(value) {
                if (is.null(value) || length(value) == 0 || is.na(value) || value == "") {
                        return(span(class = "saved-value", "—"))
                }
                span(class = "saved-value", as.character(value))
        }
        
        observeEvent(authenticated(), {
                if (isTRUE(authenticated())) {
                        pull_saved()
                        clear_statuses()
                }
        }, ignoreInit = FALSE)
        
        observe({
                req(authenticated())
                invalidateLater(60000, session)
                try({
                        pull_saved()
                }, silent = TRUE)
        })
        
        observe({
                req(authenticated())
                
                s1 <- saved_s1()
                s2 <- saved_s2()
                
                output$ascent_saved_ui <- renderUI({
                        v <- if (!is.null(s1) && "First/Ascent" %in% names(s1)) s1[["First/Ascent"]][1] else NA
                        render_saved_value(v)
                })
                
                output$sanctuary_saved_ui <- renderUI({
                        v <- if (!is.null(s1) && "Second/Sanctuary" %in% names(s1)) s1[["Second/Sanctuary"]][1] else NA
                        render_saved_value(v)
                })
                
                output$ascent_online_saved_ui <- renderUI({
                        v <- if (!is.null(s1) && "AscentOnline" %in% names(s1)) s1[["AscentOnline"]][1] else NA
                        render_saved_value(v)
                })
                
                output$sanctuary_online_saved_ui <- renderUI({
                        v <- if (!is.null(s1) && "SanctuaryOnline" %in% names(s1)) s1[["SanctuaryOnline"]][1] else NA
                        render_saved_value(v)
                })
                
                for (i in seq_along(ADULT_CLASS_COLS)) {
                        local({
                                ii <- i
                                nm <- ADULT_CLASS_COLS[ii]
                                out_id <- paste0("adult_", ii, "_saved_ui")
                                output[[out_id]] <- renderUI({
                                        v <- if (!is.null(s2) && nm %in% names(s2)) s2[[nm]][1] else NA
                                        render_saved_value(v)
                                })
                        })
                }
                
                for (i in seq_along(CHILD_CLASS_COLS)) {
                        local({
                                ii <- i
                                nm <- CHILD_CLASS_COLS[ii]
                                out_id <- paste0("child_", ii, "_saved_ui")
                                output[[out_id]] <- renderUI({
                                        v <- if (!is.null(s2) && nm %in% names(s2)) s2[[nm]][1] else NA
                                        render_saved_value(v)
                                })
                        })
                }
        })
        
        save_single_service <- function(field_id) {
                spec <- SERVICE_FIELD_MAP[[field_id]]
                button_id <- paste0("submit_", field_id)
                status_id <- paste0(field_id, "_status")
                
                d <- date_str()
                new_value <- as_int_or_na(input[[field_id]])
                
                set_buttons_enabled(FALSE, button_id)
                set_status(status_id, "Saving...", "status-wip")
                show_save_start(paste("Saving", spec$label, "..."))
                
                tryCatch({
                        written_s1 <- with_sheet_lock(SHEET1_ID, SHEET1_LOCK_TAB, SHEET1_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET1_ID, SHEET1_TAB, S1_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged[[spec$s1_col]] <- new_value
                                merged[["Date"]] <- d
                                merged <- compute_sheet1_totals(merged)
                                save_row_by_date(SHEET1_ID, SHEET1_TAB, S1_COLS, d, merged)
                        })
                        
                        written_s2 <- with_sheet_lock(SHEET2_ID, SHEET2_LOCK_TAB, SHEET2_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged[[spec$s2_col]] <- new_value
                                merged[["Date"]] <- d
                                merged <- compute_sheet2_totals(merged)
                                save_row_by_date(SHEET2_ID, SHEET2_TAB, S2_COLS, d, merged)
                        })
                        
                        saved_s1(prepare_sheet_dates(written_s1))
                        saved_s2(prepare_sheet_dates(written_s2))
                        
                        set_status(status_id, "✓ Saved", "status-ok")
                        show_save_ok("✓ Saved")
                        set_buttons_enabled(TRUE, button_id)
                }, error = function(e) {
                        set_status(status_id, paste("Save failed:", e$message), "status-err")
                        show_save_error(paste("Save failed:", e$message))
                        set_buttons_enabled(TRUE, button_id)
                })
        }
        
        save_single_classroom <- function(input_id, column_name, status_id, button_id, group = c("adult", "child")) {
                group <- match.arg(group)
                d <- date_str()
                new_value <- as_int_or_na(input[[input_id]])
                
                set_buttons_enabled(FALSE, button_id)
                set_status(status_id, "Saving...", "status-wip")
                show_save_start("Saving...")
                
                tryCatch({
                        written_s2 <- with_sheet_lock(SHEET2_ID, SHEET2_LOCK_TAB, SHEET2_LOCK_CELL, fn = function() {
                                existing <- get_saved_row(SHEET2_ID, SHEET2_TAB, S2_COLS, d)
                                merged <- as.list(existing[1, , drop = TRUE])
                                merged[[column_name]] <- new_value
                                merged[["Date"]] <- d
                                merged <- compute_sheet2_totals(merged)
                                save_row_by_date(SHEET2_ID, SHEET2_TAB, S2_COLS, d, merged)
                        })
                        
                        saved_s2(prepare_sheet_dates(written_s2))
                        
                        set_status(status_id, "✓ Saved", "status-ok")
                        show_save_ok("✓ Saved")
                        set_buttons_enabled(TRUE, button_id)
                }, error = function(e) {
                        set_status(status_id, paste("Save failed:", e$message), "status-err")
                        show_save_error(paste("Save failed:", e$message))
                        set_buttons_enabled(TRUE, button_id)
                })
        }
        
        observeEvent(input$refresh, {
                req(authenticated())
                set_buttons_enabled(FALSE, "refresh")
                set_status("refresh_status", "Refreshing...", "status-wip")
                show_save_start("Refreshing...")
                
                tryCatch({
                        pull_saved()
                        set_status("refresh_status", "✓ Refreshed", "status-ok")
                        show_save_ok("✓ Refreshed")
                        set_buttons_enabled(TRUE, "refresh")
                }, error = function(e) {
                        set_status("refresh_status", paste("Refresh failed:", e$message), "status-err")
                        show_save_error(paste("Refresh failed:", e$message))
                        set_buttons_enabled(TRUE, "refresh")
                })
        })
        
        for (field_id in names(SERVICE_FIELD_MAP)) {
                local({
                        fid <- field_id
                        observeEvent(input[[paste0("submit_", fid)]], {
                                req(authenticated())
                                save_single_service(fid)
                        })
                })
        }
        
        for (i in seq_along(ADULT_CLASS_COLS)) {
                local({
                        ii <- i
                        observeEvent(input[[paste0("submit_adult_", ii)]], {
                                req(authenticated())
                                save_single_classroom(
                                        input_id = paste0("adult_", ii),
                                        column_name = ADULT_CLASS_COLS[ii],
                                        status_id = paste0("adult_", ii, "_status"),
                                        button_id = paste0("submit_adult_", ii),
                                        group = "adult"
                                )
                        })
                })
        }
        
        for (i in seq_along(CHILD_CLASS_COLS)) {
                local({
                        ii <- i
                        observeEvent(input[[paste0("submit_child_", ii)]], {
                                req(authenticated())
                                save_single_classroom(
                                        input_id = paste0("child_", ii),
                                        column_name = CHILD_CLASS_COLS[ii],
                                        status_id = paste0("child_", ii, "_status"),
                                        button_id = paste0("submit_child_", ii),
                                        group = "child"
                                )
                        })
                })
        }
}

shinyApp(ui, server)
