        checks <- c(
                identical(as_int_or_na(row[["First/Ascent"]][1]), as_int_or_na(expected_vals[["First/Ascent"]])),
                identical(as_int_or_na(row[["Second/Sanctuary"]][1]), as_int_or_na(expected_vals[["Second/Sanctuary"]])),
                identical(as_int_or_na(row[["AscentOnline"]][1]), as_int_or_na(expected_vals[["AscentOnline"]])),
                identical(as_int_or_na(row[["SanctuaryOnline"]][1]), as_int_or_na(expected_vals[["SanctuaryOnline"]])),
                identical(as.character(row[["Church_status"]][1]), "Open")
