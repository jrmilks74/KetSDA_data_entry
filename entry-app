today_ymd <- function() {
        format(as.POSIXct(Sys.time(), tz = APP_TZ), "%Y-%m-%d")
}

sheet_date_value <- function(date_str) {
        as.Date(date_str, format = "%Y-%m-%d")
}

as_int_or_na <- function(x) {
        if (is.null(x) || length(x) == 0 || all(is.na(x))) {
                return(NA_integer_)
        }
        
        if (length(x) > 1) {
                x <- x[1]
        }
        
        if (is.character(x)) {
                x <- trimws(x)
                if (x == "") return(NA_integer_)
        }
        
        num <- suppressWarnings(as.numeric(x))
        
        if (is.na(num)) {
                return(NA_integer_)
        }
        
        as.integer(round(num))
}

empty_row <- function(cols) {
        out <- as.list(rep(NA, length(cols)))
        names(out) <- cols
        out
}

assert_headers <- function(df, expected_cols, which_sheet = "Sheet") {
        missing <- setdiff(expected_cols, names(df))
        if (length(missing) > 0) {
                stop(
                        paste0(
                                which_sheet,
                                " is missing expected columns: ",
                                paste(missing, collapse = ", ")
                        )
                )
        }
}

read_sheet_all <- function(ss, sheet) {
        read_sheet(ss = ss, sheet = sheet, col_types = "c")
}

normalize_date_string <- function(x) {
        if (length(x) == 0 || is.null(x) || all(is.na(x))) {
                return(rep(NA_character_, length(x)))
        }
        
        x <- as.character(x)
        x <- trimws(x)
        out <- rep(NA_character_, length(x))
        
        idx1 <- grepl("^\\d{4}-\\d{2}-\\d{2}$", x)
        out[idx1] <- x[idx1]
        
        idx2 <- grepl("^\\d{1,2}/\\d{1,2}/\\d{4}$", x)
        if (any(idx2)) {
                out[idx2] <- format(as.Date(x[idx2], format = "%m/%d/%Y"), "%Y-%m-%d")
        }
        
        idx3 <- grepl("^\\d{1,2}/\\d{1,2}/\\d{2}$", x)
        if (any(idx3)) {
                out[idx3] <- format(as.Date(x[idx3], format = "%m/%d/%y"), "%Y-%m-%d")
        }
        
        out
}

prepare_sheet_dates <- function(df) {
        if ("Date" %in% names(df)) {
                df$Date <- normalize_date_string(df$Date)
        }
        df
}

col_to_letter <- function(n) {
        letters_vec <- LETTERS
        out <- ""
        while (n > 0) {
                r <- (n - 1) %% 26
                out <- paste0(letters_vec[r + 1], out)
                n <- (n - 1) %/% 26
        }
        out
}

with_sheet_lock <- function(ss, sheet, lock_cell, fn, retries = 12, wait_sec = 0.4) {
        token <- paste0("LOCK_", as.numeric(Sys.time()), "_", sample.int(1e9, 1))
        
        for (i in seq_len(retries)) {
                current <- tryCatch(
                        range_read(ss, sheet = sheet, range = lock_cell, col_names = FALSE),
                        error = function(e) NULL
                )
                
                current_val <- NA_character_
                if (!is.null(current) && nrow(current) >= 1 && ncol(current) >= 1) {
                        current_val <- as.character(current[[1]][1])
                }
                
                if (is.na(current_val) || current_val == "" || current_val == "NA") {
                        range_write(
                                ss,
                                sheet = sheet,
                                range = lock_cell,
                                data = data.frame(token, stringsAsFactors = FALSE),
                                col_names = FALSE
                        )
                        
                        confirm <- tryCatch(
                                range_read(ss, sheet = sheet, range = lock_cell, col_names = FALSE),
                                error = function(e) NULL
                        )
                        
                        confirm_val <- NA_character_
                        if (!is.null(confirm) && nrow(confirm) >= 1 && ncol(confirm) >= 1) {
                                confirm_val <- as.character(confirm[[1]][1])
                        }
                        
                        if (!is.na(confirm_val) && identical(confirm_val, token)) {
                                on.exit({
                                        tryCatch(
                                                range_write(
                                                        ss,
                                                        sheet = sheet,
                                                        range = lock_cell,
                                                        data = data.frame("", stringsAsFactors = FALSE),
                                                        col_names = FALSE
                                                ),
                                                error = function(e) NULL
                                        )
                                }, add = TRUE)
                                
                                return(fn())
                        }
                }
                
                Sys.sleep(wait_sec)
        }
        
        stop("Another device is saving right now. Please try again.")
}

get_saved_row <- function(ss, sheet, cols, date_str) {
        df <- read_sheet_all(ss, sheet)
        assert_headers(df, cols, paste0(ss, "/", sheet))
        df <- prepare_sheet_dates(df)
        
        hit <- df %>%
                filter(.data$Date == date_str) %>%
                select(all_of(cols))
        
        if (nrow(hit) == 0) {
                row <- empty_row(cols)
                row$Date <- date_str
                return(as.data.frame(row, stringsAsFactors = FALSE))
        }
        
        hit[1, , drop = FALSE]
}

upsert_by_date <- function(ss, sheet, cols, date_str, new_values_named) {
        df <- read_sheet_all(ss, sheet)
        assert_headers(df, cols, paste0(ss, "/", sheet))
        df <- prepare_sheet_dates(df)
        
        row_exists <- which(df$Date == date_str)
        
        if (length(row_exists) > 0) {
                idx <- row_exists[1]
                existing <- df[idx, cols, drop = FALSE]
                
                for (nm in names(new_values_named)) {
                        if (nm %in% cols) existing[[nm]] <- new_values_named[[nm]]
                }
                
                existing$Date <- sheet_date_value(date_str)
                
                sheet_row <- idx + 1
                last_col_letter <- col_to_letter(length(cols))
                a1 <- paste0("A", sheet_row, ":", last_col_letter, sheet_row)
                
                range_write(
                        ss,
                        sheet = sheet,
                        range = a1,
                        data = existing,
                        col_names = FALSE
                )
                
                invisible(existing)
        } else {
                row <- empty_row(cols)
                row$Date <- sheet_date_value(date_str)
                
                for (nm in names(new_values_named)) {
                        if (nm %in% cols) row[[nm]] <- new_values_named[[nm]]
                }
                
                row$Date <- sheet_date_value(date_str)
                new_df <- as.data.frame(row, stringsAsFactors = FALSE)
                
                next_row <- nrow(df) + 2
                range_write(
                        ss,
                        sheet = sheet,
                        range = paste0("A", next_row),
                        data = new_df,
                        col_names = FALSE
                )
                
                invisible(new_df)
        }
}

compute_sheet1_totals <- function(vals) {
        ascent <- as_int_or_na(vals[["First/Ascent"]])
        sanct <- as_int_or_na(vals[["Second/Sanctuary"]])
        ascent_online <- as_int_or_na(vals[["AscentOnline"]])
        sanct_online <- as_int_or_na(vals[["SanctuaryOnline"]])
        
        total <- if (is.na(ascent) && is.na(sanct)) {
                NA_integer_
        } else {
                sum(c(ascent, sanct), na.rm = TRUE)
        }
        
        vals[["First/Ascent"]] <- ascent
        vals[["Second/Sanctuary"]] <- sanct
        vals[["AscentOnline"]] <- ascent_online
        vals[["SanctuaryOnline"]] <- sanct_online
        vals[["total.attendance"]] <- total
        vals[["Church_status"]] <- "Open"
        
        vals
}

compute_sheet2_totals <- function(vals) {
        ascent <- as_int_or_na(vals[["Ascent"]])
        sanct <- as_int_or_na(vals[["Sanctuary"]])
        ascent_online <- as_int_or_na(vals[["Ascent Online"]])
        sanct_online <- as_int_or_na(vals[["Sanctuary Online"]])
        
        total_inperson <- if (is.na(ascent) && is.na(sanct)) {
                NA_integer_
        } else {
                sum(c(ascent, sanct), na.rm = TRUE)
        }
        
        total_online <- if (is.na(ascent_online) && is.na(sanct_online)) {
                NA_integer_
        } else {
                sum(c(ascent_online, sanct_online), na.rm = TRUE)
        }
        
        adult_vals <- lapply(ADULT_CLASS_COLS, function(nm) as_int_or_na(vals[[nm]]))
        total_adults <- if (all(vapply(adult_vals, is.na, logical(1)))) {
                NA_integer_
        } else {
                sum(unlist(adult_vals), na.rm = TRUE)
        }
        
        child_vals <- lapply(CHILD_CLASS_COLS, function(nm) as_int_or_na(vals[[nm]]))
        total_children <- if (all(vapply(child_vals, is.na, logical(1)))) {
                NA_integer_
        } else {
                sum(unlist(child_vals), na.rm = TRUE)
        }
        
        vals[["Ascent"]] <- ascent
        vals[["Sanctuary"]] <- sanct
        vals[["Ascent Online"]] <- ascent_online
        vals[["Sanctuary Online"]] <- sanct_online
        vals[["Total In Person"]] <- total_inperson
        vals[["Total Online"]] <- total_online
        vals[["Total Adults"]] <- total_adults
        vals[["Total Children"]] <- total_children
        
        vals
}

